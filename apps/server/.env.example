# Copy to .env for local development (docker-compose up -d postgres).
DATABASE_URL=postgres://antiphon:antiphon@localhost:5433/antiphon
PORT=8787

# Blob storage: "fs" (dev, default) or "s3" (Cloudflare R2 in prod).
BLOB_DRIVER=fs
BLOB_FS_ROOT=./data/blobs

# Only required when BLOB_DRIVER=s3.
S3_ENDPOINT=
S3_BUCKET=antiphon
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Path-style addressing (endpoint/bucket/key): 1 for MinIO, 0 for R2/AWS.
S3_FORCE_PATH_STYLE=0

# Optional: local MinIO instead of fs — exercises the prod S3 driver
# (docker compose up -d minio; the server creates the bucket at boot):
# BLOB_DRIVER=s3
# S3_ENDPOINT=http://localhost:9100
# S3_BUCKET=antiphon-dev
# S3_ACCESS_KEY_ID=antiphon
# S3_SECRET_ACCESS_KEY=antiphon-secret
# S3_FORCE_PATH_STYLE=1
# S3_REGION=us-east-1

# Recognized but UNSUPPORTED: node-datachannel (libdatachannel/libjuice)
# exposes no external-address hint, so the server cannot advertise this IP
# as an ICE candidate — setting it only logs a startup WARN. Hosts behind
# 1:1 NAT (EC2/GCP) are unsupported; deploy on a VM with the public IP
# bound to its NIC (docs/deploy.md §5).
# WEBRTC_PUBLIC_IP=

# Logging: debug | info | warn | error (JSON lines on stdout).
LOG_LEVEL=info

# CORS allowlist for /api/* (comma-separated origins). Unset = allow all
# origins — dev only; a startup warning is logged.
# CORS_ORIGINS=https://antiphon.example.com,https://desk.example.com

# Trust X-Forwarded-For for client IPs (set to 1 behind a reverse proxy).
TRUST_PROXY=0

# Join (WS upgrade) rate limit per IP (RFC §12 MUST): sustained/min + burst.
JOIN_RATE_PER_MIN=30
JOIN_RATE_BURST=10

# Per-connection signaling message flood guard: sustained/sec + burst.
# Abusers get a control-plane error {code:"rate-limited"} and a disconnect.
SIGNALING_MSG_RATE_PER_SEC=100
SIGNALING_MSG_BURST=200

# Capacity caps: exceeding joins get {code:"session-full"|"server-full"}.
MAX_PEERS_PER_SESSION=32
MAX_ACTIVE_SESSIONS=200

# Session retention (RFC §12 MUST): sessions idle longer than the TTL are
# hard-deleted (blobs + rows) by a periodic sweep. Sessions with connected
# peers or an active take are never swept. 720 h = 30 days.
SESSION_TTL_HOURS=720
SESSION_SWEEP_INTERVAL_MS=600000

# In-memory collab (Yjs) rooms with zero connected desks are evicted after
# this idle grace (doc flushed to Postgres first; a rejoin rebuilds it
# transparently). 900000 ms = 15 min. Max 2147483647 (~24.8 days, the
# 32-bit timer ceiling) — larger values are rejected at boot.
COLLAB_IDLE_EVICT_MS=900000
