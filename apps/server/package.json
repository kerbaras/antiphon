{
  "name": "@antiphon/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/check-node.cjs",
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "prestart": "node ../../scripts/check-node.cjs",
    "start": "node --env-file-if-exists=.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@antiphon/core-wasm": "workspace:*",
    "@antiphon/protocol": "workspace:*",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@clerk/backend": "^3.10.0",
    "@hono/node-server": "^2.0.8",
    "@hono/node-ws": "^1.3.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "node-datachannel": "^0.32.3",
    "postgres": "^3.4.9",
    "y-protocols": "1.0.7",
    "yjs": "13.6.31",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
