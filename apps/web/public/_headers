# Cloudflare Pages headers (copied into dist/ by Vite).
# COOP/COEP on every route: SharedArrayBuffer requires cross-origin
# isolation — mirrors the dev headers in apps/web/vite.config.ts.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Vite emits content-hashed filenames under /assets — cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The HTML shell must revalidate so deploys ship instantly.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
