{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "pkg/**"]
    },
    "@antiphon/core-wasm#build": {
      "dependsOn": ["^build"],
      "outputs": ["pkg/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../wasm/**",
        "../core/src/**",
        "../codec/src/**",
        "../dsp/src/**",
        "../../Cargo.toml"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@antiphon/core-wasm#test": {
      "dependsOn": ["build"]
    },
    "@antiphon/core-wasm#typecheck": {
      "dependsOn": ["build"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
