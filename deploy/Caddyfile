# Caddy config for the production VM (docker-compose.prod.yml mounts this
# at /etc/caddy/Caddyfile). Replace the two placeholders:
#   antiphon.example.com  -> your domain (DNS A/AAAA record -> this VM)
#   antiphon.pages.dev    -> your Cloudflare Pages deployment hostname
#
# TLS is automatic (Let's Encrypt). WebSockets are proxied automatically by
# reverse_proxy — no extra directives needed for /session/*/ws, /join/*/ws.
#
# The web app is same-origin by design (it fetches /api/* and opens WS to
# location.host — apps/web/src/net/signaling-client.ts), so this vhost is
# the single public origin: backend paths go to the server on localhost,
# everything else is the frontend.

antiphon.example.com {
	encode zstd gzip

	# Control plane + archive REST + WS signaling -> app server (host net).
	@backend path /api/* /session/*/ws /join/*/ws /health /ready
	handle @backend {
		reverse_proxy localhost:8787
	}

	# Frontend, option A (default): proxy to Cloudflare Pages. COOP/COEP and
	# cache headers come from apps/web/public/_headers on Pages and pass
	# through untouched.
	handle {
		reverse_proxy https://antiphon.pages.dev {
			header_up Host antiphon.pages.dev
		}
	}

	# Frontend, option B: serve a local build instead of Pages. Comment out
	# the handle block above, copy apps/web/dist to /srv/antiphon-web on the
	# VM, add `- /srv/antiphon-web:/srv/antiphon-web:ro` to the caddy volumes
	# in docker-compose.prod.yml, and uncomment:
	#
	# handle {
	# 	root * /srv/antiphon-web
	# 	header Cross-Origin-Opener-Policy same-origin
	# 	header Cross-Origin-Embedder-Policy require-corp
	# 	@hashed path /assets/*
	# 	header @hashed Cache-Control "public, max-age=31536000, immutable"
	# 	@html path / /index.html
	# 	header @html Cache-Control no-cache
	# 	try_files {path} /index.html
	# 	file_server
	# }
}
