# Production environment — copy to the repo root as .env.prod and fill in.
#   cp deploy/.env.prod.example .env.prod
# .env.prod is gitignored; NEVER commit real values. Lines marked SECRET
# must be generated per deployment.
#
# Used twice by docker-compose.prod.yml:
#   - `docker compose --env-file .env.prod ...` for ${...} substitution
#     (POSTGRES_* feed the postgres container)
#   - `env_file: .env.prod` for the server process itself

# ---- Postgres (compose) ----------------------------------------------------
POSTGRES_USER=antiphon
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM        # SECRET — openssl rand -hex 24
POSTGRES_DB=antiphon

# ---- Server core -------------------------------------------------------------
# Must agree with POSTGRES_* above. localhost works because the server runs
# with host networking and postgres publishes 127.0.0.1:5432.
DATABASE_URL=postgres://antiphon:CHANGE_ME_LONG_RANDOM@localhost:5432/antiphon   # SECRET (embeds the password)
PORT=8787

# ---- Blob storage: Cloudflare R2 (recommended — free egress) ----------------
BLOB_DRIVER=s3
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=antiphon-blobs
S3_ACCESS_KEY_ID=CHANGE_ME                     # SECRET — R2 API token
S3_SECRET_ACCESS_KEY=CHANGE_ME                 # SECRET — R2 API token
S3_REGION=auto
# Or local disk instead of R2 (enable the blobdata volume in compose):
# BLOB_DRIVER=fs
# BLOB_FS_ROOT=/data/blobs

# ---- Hardening (see apps/server/.env.example for semantics) ------------------
LOG_LEVEL=info
# The public web-app origin(s); unset would allow ALL origins on /api/*.
CORS_ORIGINS=https://antiphon.example.com
# Caddy fronts all HTTP(S): trust X-Forwarded-For for rate-limit keying.
TRUST_PROXY=1

# Join (WS upgrade) rate limit per IP + per-connection message flood guard.
JOIN_RATE_PER_MIN=30
JOIN_RATE_BURST=10
SIGNALING_MSG_RATE_PER_SEC=100
SIGNALING_MSG_BURST=200

# Capacity caps.
MAX_PEERS_PER_SESSION=32
MAX_ACTIVE_SESSIONS=200

# Retention: idle sessions are hard-deleted (blobs + rows) after the TTL.
SESSION_TTL_HOURS=720
SESSION_SWEEP_INTERVAL_MS=600000

# ---- WebRTC ------------------------------------------------------------------
# Documented for forward-compat but NOT read by the server yet: ingest
# creates PeerConnection({iceServers: []}), so host ICE candidates are the
# addresses actually on the NIC. Pick a VM whose public IP is bound to the
# interface (Hetzner default) and this just works; behind 1:1 NAT (EC2 etc.)
# ingest will NOT connect today. See docs/deploy.md "WEBRTC_PUBLIC_IP".
# WEBRTC_PUBLIC_IP=203.0.113.10
