{
  "name": "@antiphon/core-wasm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Built wasm artifacts from packages/wasm — the ONLY way TS consumes Rust",
  "exports": {
    ".": "./src/index.ts",
    "./pkg/*": "./pkg/*"
  },
  "scripts": {
    "build": "wasm-pack build ../wasm --target web --out-dir ../core-wasm/pkg --out-name antiphon",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
